table Measure
	lineageTag: 7ac63de8-ccba-4384-a73c-1fb7117deef2

	measure 'Total Sales Amount' =
			
			SUM(Fact_Real_Estate_Sales[Sale Amount])
		formatString: #,0
		lineageTag: 3d9ea211-d2d4-4f86-a9c4-8b5e13e30f93

	measure 'Median Price' = ```
			
			CALCULATE(
			    MEDIAN(Fact_Real_Estate_Sales[Sale Amount]),
			    Fact_Real_Estate_Sales[Sales Ratio] >= 0.7 && Fact_Real_Estate_Sales[Sales Ratio] <= 1.1,
			    Fact_Real_Estate_Sales[Assessed Value] <> 0
			)
			
			```
		lineageTag: 002bdb9f-e9ef-4dd5-8ca1-5013e65145f4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Real Estate Sales' =
			
			COUNT(Fact_Real_Estate_Sales[UniqueSalesID])
		formatString: 0
		lineageTag: fa0cc5d3-a11a-4c30-be64-64c4767ae140

	measure 'Property Type Qty' =
			
			CALCULATE(
			    COUNTX(Fact_Real_Estate_Sales,Fact_Real_Estate_Sales[Property Type])
			)
		formatString: 0
		lineageTag: 71d2c1c0-654f-445a-b4ca-f6c93784600c

	measure 'Sale Amount YoY' =
			
			CALCULATE(
			    [Total Sales Amount],
			        SAMEPERIODLASTYEAR(Fact_Real_Estate_Sales[FY])
			)
		formatString: 0
		lineageTag: 94661480-4b81-4e46-9b26-665b57e3d943

	measure 'Growth Sale Amount YoY' =
			
			CALCULATE(
			    [Total Sales Amount] - [Sale Amount YoY]
			)
		formatString: 0
		lineageTag: 8a6c8684-914f-4986-93a7-06fc119bfa12

	measure '% Growth Sale Amount YoY' =
			
			CALCULATE(
			    DIVIDE(
			        [Total Sales Amount] - [Sale Amount YoY],[Sale Amount YoY])
			)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: d505e4b4-1496-41db-9d4e-de0c6888301a

	measure 'Real Estate YoY' =
			
			CALCULATE(
			    [Total Real Estate Sales],
			    SAMEPERIODLASTYEAR(Fact_Real_Estate_Sales[FY])
			)
		formatString: 0
		lineageTag: f9cc9066-befb-4580-812f-0799490247e3

	measure 'Growth Real Estate YoY' =
			
			[Total Real Estate Sales] - [Real Estate YoY]
		formatString: 0
		lineageTag: f1a3bbf2-cbc4-471a-afca-fd8777cb3e8d

	measure 'Global Median Sales Ratio' = ```
			
			CALCULATE(
			    MEDIAN(Fact_Real_Estate_Sales[Sales Ratio]),
			    Fact_Real_Estate_Sales[Assessed Value] <> 0
			)
			
			```
		formatString: #,0.0000
		lineageTag: 5c852190-2e52-405b-9f90-fbcc89a80e16

	measure '% Growth Real Estate YoY' =
			
			CALCULATE(
			    DIVIDE(
			        [Growth Real Estate YoY],[Real Estate YoY])
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 74cda6ed-cd89-42e4-b018-e89f95306a77

	measure 'Global Median Price CT' = ```
			
